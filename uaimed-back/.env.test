NODE_ENV=test
PORT=3334

# PostgreSQL (Docker) - banco SEPARADO para testes (nunca apaga dados de desenvolvimento)
DATABASE_URL="postgresql://docker:docker@localhost:5432/uaimed_test"

JWT_SECRET="uaimed-jwt-secret-test-only"
JWT_EXPIRE_IN="1d"
# BCRYPT_ROUNDS=4 acelera muito os testes (hash mais fraco, mas suficiente para CI)
BCRYPT_ROUNDS=4
FRONTEND_URL="http://localhost:19000"

